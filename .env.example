# ── Knowledge Graph Extraction Agent ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and should NEVER be committed to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Required: your Anthropic API key
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used by the agent (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: maximum tokens for each Claude response (default: 2048 for tools, 4096 for agent loop)
# ANTHROPIC_MAX_TOKENS=2048

# FalkorDB connection (used by insert_into_falkordb tool)
# FALKORDB_HOST=localhost
# FALKORDB_PORT=6379
# FALKORDB_PASSWORD=
# FALKORDB_GRAPH=knowledge_graph
